<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Clement Task Tracker</display-name>

    <servlet>
        <servlet-name>TaskServlet</servlet-name>
        <servlet-class>com.clement.servlet.TaskServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>CreateTaskServlet</servlet-name>
        <servlet-class>com.clement.servlet.CreateTaskServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>UpdateTaskServlet</servlet-name>
        <servlet-class>com.clement.servlet.UpdateTaskServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>DeleteTaskServlet</servlet-name>
        <servlet-class>com.clement.servlet.DeleteTaskServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>TaskServlet</servlet-name>
        <url-pattern>/tasks</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>CreateTaskServlet</servlet-name>
        <url-pattern>/create-task</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>UpdateTaskServlet</servlet-name>
        <url-pattern>/update-task</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>DeleteTaskServlet</servlet-name>
        <url-pattern>/delete-task</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <cookie-config>
            <secure>false</secure>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>
</web-app>
